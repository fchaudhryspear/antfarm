{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Structured Findings Schema v1.0",
  "description": "Standard format for review swarm findings consumed by fix swarm. Replaces freetext findings handoff.",
  "type": "object",
  "required": ["version", "repo_name", "repo_path", "generated_by", "generated_at", "overall_score", "domain_scores", "findings"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0",
      "description": "Schema version for forward compatibility"
    },
    "repo_name": {
      "type": "string",
      "description": "Repository name (e.g., 'flobase', 'data-lake')"
    },
    "repo_path": {
      "type": "string",
      "description": "Absolute path to the repo on disk"
    },
    "generated_by": {
      "type": "string",
      "const": "swarm-code-review-v3",
      "description": "Which workflow produced these findings"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of generation"
    },
    "overall_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "domain_scores": {
      "type": "object",
      "description": "Per-domain scores from review agents",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0,
        "maximum": 100
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/finding"
      }
    }
  },
  "definitions": {
    "finding": {
      "type": "object",
      "required": ["finding_id", "domain", "severity", "file", "description", "review_agent", "confidence"],
      "properties": {
        "finding_id": {
          "type": "string",
          "pattern": "^[A-Z]{2,4}-\\d{3}$",
          "description": "Stable ID: domain prefix + 3-digit counter. SEC-001, BE-002, PERF-003, etc.",
          "examples": ["SEC-001", "BE-002", "PERF-003", "TEST-001", "CQ-004", "FE-001", "DO-002", "UX-001", "DOC-003", "PROD-001"]
        },
        "domain": {
          "type": "string",
          "enum": ["security", "backend", "performance", "testing", "code-quality", "frontend", "devops", "ux", "documentation", "product"]
        },
        "severity": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"]
        },
        "file": {
          "type": "string",
          "description": "Relative path from repo root (e.g., 'src/api/upload.py')"
        },
        "line_range": {
          "type": "array",
          "items": { "type": "integer" },
          "minItems": 2,
          "maxItems": 2,
          "description": "Start and end line numbers [start, end]. Null if file-level finding."
        },
        "description": {
          "type": "string",
          "description": "What the problem is — one or two sentences max"
        },
        "suggested_approach": {
          "type": "string",
          "description": "How to fix it — actionable, specific"
        },
        "category_tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Classification tags (e.g., 'input-validation', 'owasp-a03', 'n-plus-one', 'missing-test')"
        },
        "review_agent": {
          "type": "string",
          "description": "ID of the review agent that produced this finding"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Review agent's confidence in this finding (0.0-1.0)"
        },
        "related_findings": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Finding IDs that share root cause or touch the same file"
        },
        "shared_file": {
          "type": "boolean",
          "description": "True if this file appears in findings from 2+ domains. Set by consolidator."
        }
      }
    }
  }
}
